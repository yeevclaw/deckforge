# Files excluded from `git archive` output (i.e. the deckforge.zip
# we ship to GitHub Releases via scripts/package.sh, and also the
# zip GitHub's "Code → Download ZIP" button produces).
#
# These files remain in the git tree and on github.com — they are
# only kept out of the slim skill bundle so users don't upload 800KB
# of demo assets to Claude Desktop just to install the skill.
#
# Anything Claude needs at runtime (SKILL.md, prompts/, references/,
# templates/, scripts/svg_to_pptx.py, scripts/setup.{sh,ps1},
# requirements.txt, LICENSE) is NOT listed here and ships normally.

# Demo / showcase assets — visible in the GitHub README, not used at runtime
examples/ export-ignore

# GitHub-facing docs — Claude Desktop shows the skill description from
# SKILL.md frontmatter, never from README.
README.md     export-ignore
README.en.md  export-ignore

# Maintainer tools, not user-facing runtime assets
scripts/package.sh export-ignore
scripts/check_docs.py export-ignore
scripts/golden_check.sh export-ignore

# Maintainer process doc under references/, not a runtime asset
references/improvement_loop.md export-ignore

# Claude Code guidance for repo development — not a runtime asset
CLAUDE.md export-ignore

# Pure git metadata
.gitignore     export-ignore
.gitattributes export-ignore
